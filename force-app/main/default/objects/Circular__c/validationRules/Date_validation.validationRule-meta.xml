<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Date_validation</fullName>
    <active>true</active>
    <errorConditionFormula>Expiry_Date__c &lt; TODAY()</errorConditionFormula>
    <errorDisplayField>Expiry_Date__c</errorDisplayField>
    <errorMessage>Expiry date cannot be in the past.</errorMessage>
</ValidationRule>
